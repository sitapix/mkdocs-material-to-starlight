{
  "name": "mkdocs-material-to-starlight",
  "version": "0.2.1",
  "description": "Migrate MkDocs Material sites to Astro Starlight in one command. Maps pages, plugins, sidebar, redirects, and i18n; reports anything left over with file:line diagnostics.",
  "type": "module",
  "license": "MIT",
  "author": "sitapix",
  "homepage": "https://github.com/sitapix/mkdocs-material-to-starlight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitapix/mkdocs-material-to-starlight.git"
  },
  "bugs": {
    "url": "https://github.com/sitapix/mkdocs-material-to-starlight/issues"
  },
  "keywords": [
    "mkdocs",
    "mkdocs-material",
    "astro",
    "starlight",
    "documentation",
    "migration",
    "converter",
    "markdown",
    "mdx",
    "remark",
    "unified"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/interface/api/index.d.ts",
      "default": "./dist/interface/api/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "mkdocs-material-to-starlight": "./dist/interface/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests",
    "format": "biome format --write src tests",
    "check": "biome check --write src tests",
    "check:ci": "biome ci --diagnostic-level=error src tests",
    "knip": "knip",
    "audit:release": "npm audit --omit=dev --audit-level=moderate",
    "regen-fixtures": "npm run build && node scripts/regen-fixtures.mjs",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run typecheck && npm run check:ci && npm run knip && npm test && npm run audit:release && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "gemoji": "^8.1.0",
    "js-yaml": "^4.1.1",
    "mdast-util-mdx-jsx": "^3.2.0",
    "picocolors": "^1.1.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    },
    "pixelmatch": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "pngjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@fast-check/vitest": "^0.4.1",
    "@mdx-js/mdx": "^3.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "knip": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
