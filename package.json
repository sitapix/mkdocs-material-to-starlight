{
  "name": "mkdocs-material-to-starlight",
  "version": "0.1.0",
  "description": "Convert MkDocs Material documentation sites to Astro Starlight with isolated, idempotent transforms and built-in MDX/Markdown parse validation.",
  "type": "module",
  "license": "MIT",
  "author": "sitapix",
  "homepage": "https://github.com/sitapix/mkdocs-material-to-starlight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitapix/mkdocs-material-to-starlight.git"
  },
  "bugs": {
    "url": "https://github.com/sitapix/mkdocs-material-to-starlight/issues"
  },
  "keywords": [
    "mkdocs",
    "mkdocs-material",
    "astro",
    "starlight",
    "documentation",
    "migration",
    "converter",
    "markdown",
    "mdx",
    "remark",
    "unified"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/interface/api/index.d.ts",
      "default": "./dist/interface/api/index.js"
    }
  },
  "bin": {
    "mkdocs-material-to-starlight": "./dist/interface/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@mdx-js/mdx": "^3.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "pixelmatch": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "pngjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
