# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Astro build cache (generated by `astro dev` / `astro build` — never tracked,
# including under tests/fixtures/real-world/<site>-out/).
.astro/

# Test artifacts
coverage/
.vitest-cache/
.vitest-reports/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Environment / local config
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Converter scratch output (generated by running the CLI locally)
/tmp-out/
/out/
*-out-local/

# Optional adapter artifacts (Playwright is a lazy import; not committed)
/playwright-report/
/test-results/

# Stray converter artifacts (when the CLI is accidentally run against this
# repo: README.md → index.md, etc.). Keep the layer READMEs canonical.
/index.md
/src/domain/index.md
/src/use-cases/index.md
/src/infrastructure/index.md
/src/interface/index.md

# Agent / planning scratch (not user-facing docs)
/docs/superpowers/
CLAUDE.md

# Real-world fixture corpus is local-only. Both source clones and
# converter outputs stay out of git. See tests/fixtures/real-world/README.md.
/tests/fixtures/real-world/*/
!/tests/fixtures/real-world/README.md

# Serena MCP local cache
/.serena/
